# =============================================================================
# QTL_Bot - .env.example
# このファイルをコピーして .env にリネームし、値を設定してください。
#   cp .env.example .env
# ★ 必須項目は「# ★必須」と記載しています。それ以外はデフォルト値で動作します。
# =============================================================================


# =============================================================================
# ■ Discord 設定
# =============================================================================

# Bot トークン（Discord Developer Portal → Bot タブ）                   ★必須
BOT_TOKEN=your_discord_bot_token_here

# デフォルト通知チャンネル ID（全通知のフォールバック先）                ★必須
# 以下の専用チャンネル ID が未設定の場合、この ID が使用されます
CHANNEL_ID=123456789012345678

# --- 専用チャンネル（未設定時は CHANNEL_ID にフォールバック） ---
# EEW（緊急地震速報）通知チャンネル
#EEW_CHANNEL_ID=

# 地震情報通知チャンネル
#QUAKE_CHANNEL_ID=

# 津波警報通知チャンネル
#TSUNAMI_CHANNEL_ID=

# 火山情報通知チャンネル
#VOLCANO_CHANNEL_ID=

# USGS 海外地震情報チャンネル（未設定時は QUAKE_CHANNEL_ID）
#USGS_CHANNEL_ID=

# 長周期地震動・強震モニタ等その他通知チャンネル
#OTHER_CHANNEL_ID=

# --- EEW フォールバック専用チャンネル（未設定時は EEW_CHANNEL_ID） ---
# P2P EEW フォールバック通知チャンネル
#P2P_EEW_CHANNEL_ID=

# LMoni EEW フォールバック通知チャンネル
#LMONI_EEW_CHANNEL_ID=

# 強震モニタ専用チャンネル（未設定時は OTHER_CHANNEL_ID）
#KYOSHIN_CHANNEL_ID=

# エラー自動通知チャンネル（管理者向け。0 で無効）
#ADMIN_CHANNEL_ID=0


# =============================================================================
# ■ 通知フィルター設定
# =============================================================================

# --- 地震情報フィルター ---
# 震度下限（0=全て / 10=震度1以上 / 30=震度3以上 / 45=震度4以上 / 50=震度5弱以上）
#QUAKE_MIN_SCALE=0

# マグニチュード下限（0.0=全て）
#QUAKE_MIN_MAG=0.0

# 震源の深さ範囲（km）
#QUAKE_MIN_DEPTH=0
#QUAKE_MAX_DEPTH=9999

# --- 地震情報 種別ごとの有効化（true/false）---
#QUAKE_ENABLE_SCALE_PROMPT=true    # 震度速報
#QUAKE_ENABLE_DESTINATION=true     # 震度情報付き地震
#QUAKE_ENABLE_SCALE_AND_DEST=true  # 震度・震源情報付き地震
#QUAKE_ENABLE_DETAIL_SCALE=true    # 詳細震度情報
#QUAKE_ENABLE_FOREIGN=true         # 海外地震
#QUAKE_ENABLE_OTHER=true           # その他地震情報

# --- EEW フィルター ---
# EEW 通知の最低震度（0=全て通知、INT_MAP の数値キー）
#EEW_MIN_INTENSITY=0

# --- 各種機能の有効化 ---
#TSUNAMI_ENABLE=true       # 津波情報通知
#ENABLE_LONG_PERIOD=true   # 長周期地震動通知
#ENABLE_ADVISORY=true      # 気象庁その他情報
#ENABLE_TSUNAMI_OBS=true   # 津波観測情報
#ENABLE_KYOSHIN=true       # 強震モニタ通知


# =============================================================================
# ■ USGS 海外地震情報設定
# =============================================================================

# USGS 通知機能の有効化
#USGS_ENABLED=true

# 通知対象のマグニチュード下限
#USGS_MAGNITUDE_MIN=5.0

# ポーリング間隔（秒。デフォルト 10分）
#USGS_FETCH_INTERVAL=600

# 通知対象地域（緯度・経度の範囲）
# デフォルト: 日本周辺（緯度 20〜50度、経度 120〜180度）
#USGS_REGION_LAT_MIN=20
#USGS_REGION_LAT_MAX=50
#USGS_REGION_LON_MIN=120
#USGS_REGION_LON_MAX=180

# 重複通知防止クールダウン（秒。デフォルト 5分）
#USGS_NOTIFICATION_COOLDOWN=300


# =============================================================================
# ■ EEW・フォールバック設定
# =============================================================================

# Wolfx heartbeat タイムアウト（秒）。この時間 heartbeat がなければ切断判定
#WOLFX_HEARTBEAT_TIMEOUT=90

# フォールバック切り替え閾値（秒）。Wolfx からの EEW 受信が途絶えたら P2P/LMoni に切り替え
#EEW_FALLBACK_TIMEOUT=30

# API 連続失敗回数がこの値を超えたらエラー通知
#FETCH_FAILURE_THRESHOLD=3

# API 失敗時のバックオフ待機時間（秒）
#FETCH_BACKOFF_SECONDS=60


# =============================================================================
# ■ 音声読み上げ設定
# =============================================================================

# AquesTalkPi 実行ファイルパス（空欄で音声無効）
# ディレクトリを指定した場合、AquesTalkPi / aquestalkpi を自動補完します
#AQUESTALK_PATH=/home/user/opt/aquestalkpi/AquesTalkPi

# 読み上げ速度（50〜300 程度。デフォルト 150）
#AQUESTALK_SPEED=150

# 音声再生コマンド（aplay / mpg123 等、環境に合わせて変更）
#AUDIO_PLAYER=aplay

# 音声読み上げキューの最大サイズ（溢れた分は破棄）
#SPEECH_QUEUE_MAXSIZE=200

# MP3 再生キューの最大サイズ
#MP3_QUEUE_MAXSIZE=50


# =============================================================================
# ■ ログ設定
# =============================================================================

# ログレベル（後方互換。LOG_LEVEL_FILE / LOG_LEVEL_CONSOLE が未設定の場合の既定値）
# DEBUG / INFO / WARNING / ERROR / CRITICAL
#LOG_LEVEL=INFO

# ファイルへの出力ログレベル（詳細ログを残したい場合は DEBUG）
#LOG_LEVEL_FILE=INFO

# コンソールへの出力ログレベル（systemd journalctl で見るレベル）
#LOG_LEVEL_CONSOLE=INFO

# ログファイルの最大サイズ（バイト。デフォルト 10MB）
#LOG_MAX_BYTES=10485760

# ローテーション保持ファイル数
#LOG_BACKUP_COUNT=7

# 同一メッセージの重複抑制時間（秒）。ERROR / CRITICAL は常に出力
#LOG_DUPLICATE_THRESHOLD=60

# aiohttp.access の HTTP 2xx 成功ログを抑制（Mackerel 等の定期監視によるログ肥大化対策）
#LOG_SUPPRESS_HTTP_SUCCESS=true


# =============================================================================
# ■ Web Dashboard 設定
# =============================================================================

# Web Dashboard の有効化（curl http://localhost:PORT/status で稼働状況確認）
#WEB_DASHBOARD_ENABLED=true

# ポート番号
#WEB_DASHBOARD_PORT=8080


# =============================================================================
# ■ ステータス表示設定（!status / /qtl_status）
# =============================================================================

# CPU 使用率を表示（psutil が必要）
#STATUS_SHOW_CPU=true

# メモリ使用量を表示（psutil が必要）
#STATUS_SHOW_MEM=true

# ディスク使用率を表示（psutil が必要）
#STATUS_SHOW_DISK=true

# フィルター設定（震度下限・M下限・深さ範囲等）を表示
#STATUS_SHOW_UPTIME=true


# =============================================================================
# ■ リソース監視設定
# =============================================================================

# リソース監視の有効化（CPU・メモリ・ディスクを定期記録）
#RESOURCE_MONITORING_ENABLED=true

# 監視間隔（秒。デフォルト 1時間）
#RESOURCE_CHECK_INTERVAL=3600

# ディスク使用率 WARNING 閾値（%）
#DISK_WARNING_THRESHOLD=80

# ディスク使用率 ERROR 閾値（%）
#DISK_ERROR_THRESHOLD=90