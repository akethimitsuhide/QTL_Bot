# ============================================================
# [必須] Discord 設定
# ============================================================
BOT_TOKEN=your_discord_bot_token_here
CHANNEL_ID=000000000000000000

# ============================================================
# [任意] チャンネル ID（未設定時は CHANNEL_ID にフォールバック）
# ============================================================
EEW_CHANNEL_ID=
P2P_EEW_CHANNEL_ID=
QUAKE_CHANNEL_ID=
TSUNAMI_CHANNEL_ID=
VOLCANO_CHANNEL_ID=
OTHER_CHANNEL_ID=
KYOSHIN_CHANNEL_ID=
USGS_CHANNEL_ID=
ADMIN_CHANNEL_ID=

# ============================================================
# [任意] 音声設定
# ============================================================
# AquesTalkPi の実行ファイルパス（未設定で音声読み上げ無効）
AQUESTALK_PATH=
# 読み上げ速度（デフォルト: 150）
AQUESTALK_SPEED=150
# 音声再生コマンド（デフォルト: aplay）
AUDIO_PLAYER=aplay
# 音声キュー最大サイズ
SPEECH_QUEUE_MAXSIZE=200
MP3_QUEUE_MAXSIZE=50

# ============================================================
# [任意] EEW 設定
# ============================================================
# EEW 通知の最低震度（0=全て / 10=震度1以上 / 30=震度3以上 / 45=震度4以上 / 50=震度5弱以上）
EEW_MIN_INTENSITY=0
# Wolfx heartbeat タイムアウト秒数（デフォルト: 90）
WOLFX_HEARTBEAT_TIMEOUT=90

# ============================================================
# [任意] 地震通知フィルター
# ============================================================
# 最大震度下限（0=全て / 10=震度1以上 / 30=震度3以上 / 45=震度4以上 / 50=震度5弱以上）
QUAKE_MIN_SCALE=0
# マグニチュード下限（デフォルト: 0.0）
QUAKE_MIN_MAG=0.0
# 深さフィルター（km）
QUAKE_MIN_DEPTH=0
QUAKE_MAX_DEPTH=9999
# 地震種別ごとの通知 ON/OFF
QUAKE_ENABLE_SCALE_PROMPT=true
QUAKE_ENABLE_DESTINATION=true
QUAKE_ENABLE_SCALE_AND_DEST=true
QUAKE_ENABLE_DETAIL_SCALE=true
QUAKE_ENABLE_FOREIGN=true
QUAKE_ENABLE_OTHER=true

# ============================================================
# [任意] 機能 ON/OFF
# ============================================================
TSUNAMI_ENABLE=true
ENABLE_LONG_PERIOD=true
ENABLE_ADVISORY=true
ENABLE_TSUNAMI_OBS=true
ENABLE_KYOSHIN=true

# ============================================================
# [任意] USGS 海外地震設定
# ============================================================
USGS_ENABLED=true
USGS_MAGNITUDE_MIN=5.0
USGS_FETCH_INTERVAL=600
USGS_REGION_LAT_MIN=20
USGS_REGION_LAT_MAX=50
USGS_REGION_LON_MIN=120
USGS_REGION_LON_MAX=180
USGS_NOTIFICATION_COOLDOWN=300

# ============================================================
# [任意] API エラー挙動
# ============================================================
# 連続失敗でエラー通知するまでの回数（デフォルト: 3）
FETCH_FAILURE_THRESHOLD=3
# 失敗時のバックオフ待機秒数（デフォルト: 60）
FETCH_BACKOFF_SECONDS=60

# ============================================================
# [任意] ログ設定
# ============================================================
# ログレベル: DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
LOG_LEVEL_FILE=INFO
LOG_LEVEL_CONSOLE=INFO
# ログファイルの最大サイズ（バイト, デフォルト: 10485760 = 10MB）
LOG_MAX_BYTES=10485760
# ローテーション保持ファイル数（デフォルト: 7）
LOG_BACKUP_COUNT=7
# 同一メッセージの重複抑制秒数（デフォルト: 60）
LOG_DUPLICATE_THRESHOLD=60
# aiohttp の 2xx 成功ログを抑制（デフォルト: true）
LOG_SUPPRESS_HTTP_SUCCESS=true

# ============================================================
# [任意] Web ダッシュボード
# ============================================================
WEB_DASHBOARD_ENABLED=false
WEB_DASHBOARD_PORT=8080

# ============================================================
# [任意] !status / /qtl_status 表示設定
# ============================================================
STATUS_SHOW_CPU=true
STATUS_SHOW_MEM=true
STATUS_SHOW_DISK=true
STATUS_SHOW_UPTIME=true

# ============================================================
# [任意] リソース監視
# ============================================================
RESOURCE_MONITORING_ENABLED=true
RESOURCE_CHECK_INTERVAL=3600
DISK_WARNING_THRESHOLD=80
DISK_ERROR_THRESHOLD=90

# ============================================================
# [任意] APM (Mackerel連携) - デフォルト無効
# ============================================================
# Mackerel等でBotの稼働状況（トレーシング）を監視したい場合のみ設定。
# APM_ENABLED=false の間は他の値を設定していても一切送信されない。
#
# 注意: APM_OTLP_ENDPOINT と APM_OTLP_API_KEY_HEADER のデフォルト値は
# 実装時にMackerel公式ドキュメントへのアクセスができず、一般的な
# OpenTelemetry OTLPの慣例に基づく暫定値です。有効化する前に必ず
# https://mackerel.io/ja/docs/entry/tracing/installations/python
# で実際の値を確認してください。
APM_ENABLED=false
APM_SERVICE_NAME=QTL_Bot
APM_MACKEREL_API_KEY=
APM_OTLP_ENDPOINT=https://otlp-vmagent.mackerelio.com
APM_OTLP_API_KEY_HEADER=Mackerel-Api-Key